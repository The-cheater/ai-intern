# Ollama configuration (local fallback — slow without GPU)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# ── Fast hosted LLM APIs for question generation (set at least one) ─────────
# Gemini 2.0 Flash — free: 15 req/min, 1500 req/day → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free: 14400 req/day, ~800 tok/s → https://console.groq.com
# GROQ_MODEL options: llama-3.3-70b-versatile (default) | qwen-qwq-32b (hosted Qwen)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudinary (either set CLOUDINARY_URL or set all 3 vars below)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
